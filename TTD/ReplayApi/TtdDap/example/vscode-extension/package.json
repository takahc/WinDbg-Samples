{
    "name": "ttd-dap-extension",
    "displayName": "TTD Debug Adapter",
    "description": "Debug Adapter for Time Travel Debugging (TTD) trace files",
    "version": "1.0.0",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Debuggers"
    ],
    "contributes": {
        "debuggers": [
            {
                "type": "ttd",
                "label": "TTD Debug",
                "program": "./out/debugAdapter.js",
                "runtime": "node",
                "configurationAttributes": {
                    "launch": {
                        "required": [
                            "program"
                        ],
                        "properties": {
                            "program": {
                                "type": "string",
                                "description": "Path to the TTD trace file (.ttd)",
                                "default": "${workspaceFolder}/trace.ttd"
                            },
                            "stopOnEntry": {
                                "type": "boolean",
                                "description": "Automatically stop after launch.",
                                "default": true
                            }
                        }
                    }
                },
                "initialConfigurations": [
                    {
                        "type": "ttd",
                        "request": "launch",
                        "name": "Debug TTD Trace",
                        "program": "${workspaceFolder}/trace.ttd",
                        "stopOnEntry": true
                    }
                ],
                "configurationSnippets": [
                    {
                        "label": "TTD: Launch",
                        "description": "Launch TTD trace debugging",
                        "body": {
                            "type": "ttd",
                            "request": "launch",
                            "name": "${1:Debug TTD Trace}",
                            "program": "^\"\\${workspaceFolder}/${2:trace.ttd}\"",
                            "stopOnEntry": true
                        }
                    }
                ]
            }
        ]
    },
    "main": "./out/extension.js",
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^18.x",
        "@types/vscode": "^1.74.0",
        "typescript": "^4.9.0"
    }
}